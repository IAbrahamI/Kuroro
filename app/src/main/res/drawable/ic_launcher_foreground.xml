<?xml version="1.0" encoding="utf-8"?>
<vector xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:aapt="http://schemas.android.com/aapt"
    android:width="108dp"
    android:height="108dp"
    android:viewportWidth="108"
    android:viewportHeight="108">

    <!-- Stylized Fancy Manga Icon -->
    <group
        android:name="manga_icon"
        android:translateX="48"
        android:translateY="54"
        android:rotation="-12"> <!-- Adjusted X translation to center it better -->

        <group
            android:translateX="-30"
            android:translateY="-35">

            <!-- Book Shadow (Inner depth) -->
            <path
                android:fillColor="#22000000"
                android:pathData="M8,12 c0,-3.3 2.7,-6 6,-6 h44 c3.3,0 6,2.7 6,6 v56 c0,3.3 -2.7,6 -6,6 h-44 c-3.3,0 -6,-2.7 -6,-6 z"
                android:translateX="2"
                android:translateY="2" />

            <!-- Main Book Body with Gradient -->
            <path
                android:pathData="M8,10 c0,-3.3 2.7,-6 6,-6 h44 c3.3,0 6,2.7 6,6 v56 c0,3.3 -2.7,6 -6,6 h-44 c-3.3,0 -6,-2.7 -6,-6 z">
                <aapt:attr name="android:fillColor">
                    <gradient
                        android:startX="8"
                        android:startY="10"
                        android:endX="64"
                        android:endY="72"
                        android:type="linear">
                        <item android:offset="0" android:color="#9D50BB" /> <!-- Deep Violet -->
                        <item android:offset="1" android:color="#6E48AA" /> <!-- Royal Purple -->
                    </gradient>
                </aapt:attr>
            </path>

            <!-- Book Spine Accent -->
            <path
                android:fillColor="#BB86FC"
                android:pathData="M8,10 v56 c0,3.3 2.7,6 6,6 h5 v-68 h-5 c-3.3,0 -6,2.7 -6,6 z" />

            <!-- Hand-drawn style 'M' for Manga -->
            <path
                android:fillColor="#FFFFFF"
                android:fillAlpha="0.9"
                android:pathData="M22,25 l8,22 l8,-22 l8,22 l8,-22 v28 h-5 v-18 l-7,18 h-8 l-7,-18 v18 h-5 z" />

            <!-- Glossy Highlight -->
            <path
                android:pathData="M16,4 h40 c3.3,0 6,2.7 6,6 v10 l-46,-16 z">
                <aapt:attr name="android:fillColor">
                    <gradient
                        android:startX="16"
                        android:startY="4"
                        android:endX="62"
                        android:endY="20"
                        android:type="linear">
                        <item android:offset="0" android:color="#44FFFFFF" />
                        <item android:offset="1" android:color="#00FFFFFF" />
                    </gradient>
                </aapt:attr>
            </path>

        </group>
    </group>
</vector>
